# ============================================================
# 内容星球 SaaS — 环境变量配置
# 复制本文件为 .env.local 在本地开发，
# 在 Vercel 控制台的 Settings > Environment Variables 里配置线上版本
# ============================================================

# ── Claude API Key（必填）───────────────────────────────────
# 去 https://console.anthropic.com 申请
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx

# ── 用户账号表（简易版，后期换数据库）──────────────────────
# 格式：email:password:token:plan:credits
# 多个用户用 | 分隔
# plan 可选值：free / pro / team
# 生成 token 建议用随机字符串，如 openssl rand -hex 16
USER_ACCOUNTS=wang@example.com:password123:abc123token:pro:200|zhu@example.com:zhuhanpw:def456token:pro:200

# ── 用于 generate.js 的 token->套餐 快查表 ──────────────────
# 格式：token:plan:credits，多个用逗号分隔（与上面保持同步）
USER_TOKENS=abc123token:pro:200,def456token:pro:200

# ============================================================
# 升级为真实数据库后，替换上面两个变量，改用：
# DATABASE_URL=postgresql://...  (如 Supabase / PlanetScale)
# ============================================================
